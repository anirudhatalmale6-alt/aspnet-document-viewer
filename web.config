<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- ================================================================
       APP SETTINGS
       ================================================================ -->
  <appSettings>
    <!--
      SharedFolderPath: The UNC or local path to the shared folder to browse.
      Examples:
        \\FileServer\SharedDocs
        \\192.168.1.100\Documents
        C:\SharedDocuments
    -->
    <add key="SharedFolderPath" value="\\FileServer\SharedDocs" />
  </appSettings>

  <!-- ================================================================
       SYSTEM.WEB  (.NET Framework settings)
       ================================================================ -->
  <system.web>
    <compilation debug="false" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2"
                 maxRequestLength="2097152"
                 executionTimeout="3600" />

    <!--
      IMPERSONATION (Optional)
      ==========================
      Option A: Use App Pool identity (recommended).
        - Grant the App Pool identity (e.g., IIS AppPool\YourAppPool) read
          access on the shared folder.
        - Leave <identity> commented out.

      Option B: Explicit credentials.
        - Uncomment the line below and supply domain\username + password.
        - The specified account must have read access to the share.
    -->
    <!--
    <identity impersonate="true"
              userName="DOMAIN\ServiceAccount"
              password="YourPasswordHere" />
    -->

    <customErrors mode="RemoteOnly" />
  </system.web>

  <!-- ================================================================
       SYSTEM.WEBSERVER  (IIS 7+ Integrated Pipeline)
       ================================================================ -->
  <system.webServer>
    <!--
      maxAllowedContentLength: Maximum request size in bytes.
      Set to 2 GB (2147483648) to support large file downloads streamed
      through the handler. Adjust as needed.
    -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="2147483648" />
      </requestFiltering>
    </security>

    <!-- Ensure static content types are registered if needed -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <httpErrors errorMode="DetailedLocalOnly" />
  </system.webServer>

</configuration>
